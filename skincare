<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="保養日誌">
<title>保養日誌</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap');

  :root {
    --cream: #FAF7F2;
    --warm-white: #FDF9F4;
    --parchment: #F3EDE3;
    --blush: #E8D5C4;
    --rose-muted: #C9A99A;
    --rose: #B8806A;
    --rose-deep: #8B5E52;
    --sage: #8FA68B;
    --sage-light: #D4E0D2;
    --ink: #2A2420;
    --ink-mid: #5C4A42;
    --ink-light: #9B8880;
    --gold: #C4A96B;
    --gold-light: #EDD9A3;
    --amber-soft: #F0E4C8;
    --lavender: #D4CCE8;
    --lavender-deep: #8070A8;
    --night-bg: #1E1A2E;
    --night-card: #2A2540;
    --night-border: #3D3660;
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bottom: env(safe-area-inset-bottom, 0px);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html, body {
    height: 100%;
    background: var(--cream);
    font-family: 'Noto Serif TC', serif;
    color: var(--ink);
    overflow: hidden;
  }

  .app {
    display: flex;
    flex-direction: column;
    height: 100%;
    height: 100dvh;
    max-width: 430px;
    margin: 0 auto;
    background: var(--warm-white);
    position: relative;
    overflow: hidden;
  }

  /* Header */
  .header {
    padding: calc(var(--safe-top) + 14px) 20px 0;
    background: var(--warm-white);
    flex-shrink: 0;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .app-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: var(--rose-deep);
    letter-spacing: 0.02em;
  }

  .today-date {
    font-size: 11px;
    color: var(--ink-light);
    letter-spacing: 0.03em;
    font-weight: 300;
    text-align: right;
    line-height: 1.5;
  }

  /* Day selector */
  .day-scroll {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 14px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .day-scroll::-webkit-scrollbar { display: none; }

  .day-chip {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 7px 10px 8px;
    border-radius: 16px;
    border: 1px solid var(--blush);
    background: transparent;
    cursor: pointer;
    transition: all .2s;
    min-width: 48px;
  }
  .day-chip.active {
    background: var(--rose-deep);
    border-color: var(--rose-deep);
  }
  .day-chip.has-done {
    border-color: var(--sage);
  }
  .day-chip .day-label {
    font-size: 10px;
    color: var(--ink-light);
    font-weight: 400;
    letter-spacing: .03em;
  }
  .day-chip.active .day-label { color: rgba(255,255,255,.75); }
  .day-chip .day-num {
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    color: var(--ink);
    line-height: 1.1;
    margin-top: 2px;
  }
  .day-chip.active .day-num { color: #fff; }
  .day-chip.has-done .day-num { color: var(--sage); }
  .day-chip.has-done.active .day-num { color: #fff; }

  .done-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--sage);
    margin-top: 3px;
    opacity: 0;
    transition: opacity .2s;
  }
  .day-chip.has-done .done-dot { opacity: 1; }
  .day-chip.active .done-dot { background: rgba(255,255,255,.6); }

  /* Mode tabs */
  .mode-bar {
    display: flex;
    padding: 0 20px 12px;
    gap: 8px;
    background: var(--warm-white);
    flex-shrink: 0;
  }

  .mode-tab {
    flex: 1;
    padding: 8px 4px;
    border-radius: 10px;
    border: 1px solid var(--blush);
    background: transparent;
    font-family: 'Noto Serif TC', serif;
    font-size: 12px;
    color: var(--ink-mid);
    cursor: pointer;
    transition: all .2s;
    text-align: center;
    font-weight: 400;
  }
  .mode-tab.active {
    background: var(--rose-deep);
    border-color: var(--rose-deep);
    color: #fff;
  }
  .mode-tab.night-active {
    background: var(--lavender-deep);
    border-color: var(--lavender-deep);
    color: #fff;
  }

  /* Progress */
  .progress-section {
    padding: 0 20px 12px;
    flex-shrink: 0;
    background: var(--warm-white);
  }
  .progress-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .progress-label {
    font-size: 11px;
    color: var(--ink-light);
    letter-spacing: .04em;
  }
  .progress-count {
    font-size: 11px;
    color: var(--rose);
    font-weight: 500;
  }
  .progress-track {
    height: 3px;
    border-radius: 2px;
    background: var(--parchment);
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--rose-muted), var(--rose));
    transition: width .4s cubic-bezier(.4,0,.2,1);
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--parchment);
    margin: 0 20px 0;
    flex-shrink: 0;
  }

  /* Step list */
  .step-list {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px calc(var(--safe-bottom) + 16px);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .step-list::-webkit-scrollbar { display: none; }

  /* Section note */
  .section-note {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 10px;
    margin-bottom: 14px;
    font-size: 12px;
    line-height: 1.6;
    font-weight: 300;
  }
  .note-day {
    background: var(--amber-soft);
    color: var(--ink-mid);
    border-left: 3px solid var(--gold);
  }
  .note-night {
    background: #2A2540;
    color: #C8BEE8;
    border-left: 3px solid var(--lavender-deep);
  }
  .note-warn {
    background: #FFF0EE;
    color: #7A3830;
    border-left: 3px solid #C96058;
  }

  /* Step card */
  .step-card {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px;
    border-radius: 14px;
    border: 1px solid var(--blush);
    background: var(--warm-white);
    margin-bottom: 10px;
    cursor: pointer;
    transition: all .2s;
    position: relative;
    overflow: hidden;
  }
  .step-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
    background: var(--blush);
    transition: background .2s;
  }
  .step-card.is-next::before { background: var(--rose); }
  .step-card.is-done::before { background: var(--sage); }
  .step-card.is-done { background: var(--parchment); border-color: var(--blush); opacity: .65; }
  .step-card.is-next { border-color: var(--rose-muted); background: #FEF8F5; }

  .step-card.night-card {
    border-color: var(--night-border);
    background: var(--night-card);
  }
  .step-card.night-card::before { background: var(--night-border); }
  .step-card.night-card.is-next { border-color: #7060B8; background: #2F2A48; }
  .step-card.night-card.is-next::before { background: var(--lavender-deep); }
  .step-card.night-card.is-done { background: #221F35; opacity: .55; }

  /* Product icon */
  .prod-icon {
    width: 56px; height: 56px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    position: relative;
  }

  .step-body { flex: 1; min-width: 0; }

  .step-top-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
  }

  .step-num {
    font-size: 10px;
    font-weight: 500;
    width: 18px; height: 18px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--parchment);
    color: var(--ink-mid);
    flex-shrink: 0;
  }
  .is-next .step-num { background: var(--rose-deep); color: #fff; }
  .night-card .step-num { background: var(--night-border); color: #C8BEE8; }
  .night-card.is-next .step-num { background: var(--lavender-deep); color: #fff; }

  .step-badge {
    font-size: 9px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 8px;
    letter-spacing: .03em;
  }
  .badge-new   { background: #D4E0D2; color: #2A4F28; }
  .badge-old   { background: var(--lavender); color: #3D2F7A; }
  .badge-sample{ background: var(--gold-light); color: #5A3E00; }
  .badge-warn  { background: #FDDDD9; color: #7A2820; }
  .badge-opt   { background: var(--parchment); color: var(--ink-mid); }
  .badge-mask  { background: #F0EAD6; color: #5A4020; font-weight: 700; }

  .step-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: 2px;
  }
  .night-card .step-name { color: #E8E0F5; }
  .is-done .step-name { text-decoration: line-through; }

  .step-brand {
    font-size: 10px;
    color: var(--ink-light);
    letter-spacing: .04em;
    margin-bottom: 5px;
    font-weight: 300;
  }
  .night-card .step-brand { color: #7A6EA8; }

  .step-tip {
    font-size: 11.5px;
    color: var(--ink-light);
    line-height: 1.55;
    font-weight: 300;
  }
  .night-card .step-tip { color: #8A7EAA; }

  /* Check circle */
  .check-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .check-circle {
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1.5px solid var(--blush);
    display: flex; align-items: center; justify-content: center;
    transition: all .2s;
  }
  .is-done .check-circle {
    background: var(--sage);
    border-color: var(--sage);
  }
  .night-card .check-circle { border-color: var(--night-border); }
  .night-card.is-done .check-circle { background: var(--lavender-deep); border-color: var(--lavender-deep); }

  /* Done banner */
  .done-banner {
    padding: 24px 20px;
    text-align: center;
    border-radius: 14px;
    background: var(--sage-light);
    border: 1px solid var(--sage);
    margin-top: 4px;
  }
  .done-banner .done-icon { color: var(--rose-deep); margin-bottom: 8px; display: flex; justify-content: center; align-items: center; }
  .done-banner .done-title { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--rose-deep); margin-bottom: 4px; }
  .done-banner .done-sub { font-size: 12px; color: var(--ink-light); font-weight: 300; }

  .done-banner.night-done {
    background: #2A2540;
    border-color: var(--lavender-deep);
  }
  .done-banner.night-done .done-icon { color: #C8BEE8; }
  .done-banner.night-done .done-title { color: #C8BEE8; }
  .done-banner.night-done .done-sub { color: #7A6EA8; }

  /* Buttons */
  .reset-btn {
    width: 100%;
    padding: 11px;
    border-radius: 10px;
    border: 1px solid var(--blush);
    background: transparent;
    font-family: 'Noto Serif TC', serif;
    font-size: 12px;
    color: var(--ink-light);
    cursor: pointer;
    margin-top: 12px;
    transition: all .2s;
    letter-spacing: .04em;
  }
  .reset-btn:active { background: var(--parchment); }
  
  .complete-btn {
    background: var(--lavender-deep) !important;
    color: #fff !important;
    border-color: var(--lavender-deep) !important;
    margin-top: 8px;
    font-weight: 500;
  }
  .complete-btn:active { opacity: 0.8; }

  /* Night mode colors */
  .night-mode-bg { background: var(--night-bg) !important; }
  .night-header { background: var(--night-bg) !important; }
  .night-mode-bar { background: var(--night-bg) !important; }
  
  /* Update Night Mode Tab Colors */
  .night-mode-bar .mode-tab { 
    border-color: var(--night-border) !important; 
    color: #7A6EA8 !important; 
  }
  .night-mode-bar .mode-tab.night-active { 
    background: var(--lavender-deep) !important; 
    border-color: var(--lavender-deep) !important; 
    color: #fff !important; 
  }

  .night-progress { background: var(--night-bg) !important; }
  .night-progress .progress-track { background: #2A2540; }
  .night-progress .progress-fill { background: linear-gradient(90deg, #7060A8, #C8BEE8); }
  .night-progress .progress-count { color: #C8BEE8 !important; }
  .night-divider { background: #2A2540 !important; }
  .app-title-night { color: #C8BEE8 !important; }
  .today-date-night { color: #5A5070 !important; }
  .day-chip-night { border-color: #3D3660 !important; }
  .day-chip-night .day-label { color: #5A5070 !important; }
  .day-chip-night .day-num { color: #C8BEE8 !important; }
  .day-chip-night.active { background: var(--lavender-deep) !important; border-color: var(--lavender-deep) !important; }
  .day-chip-night.active .day-num,
  .day-chip-night.active .day-label { color: #fff !important; }
  .night-step-list { background: var(--night-bg) !important; }
  .night-reset { border-color: #3D3660 !important; color: #5A5070 !important; }

  /* Animation */
  .fade-in { animation: fadeIn .25s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .step-card { animation: fadeIn .2s ease; }
</style>
</head>
