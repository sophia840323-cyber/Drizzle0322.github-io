};

const WEEK = [
  { day:0, mode:'day', steps:['dafen','haku','meijiru'] },
  { day:0, mode:'night', steps:['dafen', 'dakin', 'feifei'] },
  { day:1, mode:'day', steps:['loccitane','zengpin_gold','meijiru'] },
  { day:1, mode:'night', steps:['loccitane','aa','feifei'] },
  { day:2, mode:'day', steps:['dafen','haku','meijiru'] },
  { day:2, mode:'night', steps:['dafen', 'mask', 'zengpin_blue', 'feifei'] }, // 面膜選填
  { day:3, mode:'day', steps:['dafen','haku','meijiru'] },
  { day:3, mode:'night', steps:['dafen', 'dakin', 'feifei'] },
  { day:4, mode:'day', steps:['loccitane','zengpin_gold','meijiru'] },
  { day:4, mode:'night', steps:['loccitane','aa','feifei'] },
  { day:5, mode:'day', steps:['dafen','haku','meijiru'] },
  { day:5, mode:'night', steps:['dafen', 'mask', 'zengpin_blue', 'feifei'] }, // 面膜選填
  { day:6, mode:'day', steps:['dafen','meijiru'] },
  { day:6, mode:'night', steps:['loccitane','feifei'] },
];

const MAKEUP_STEPS = ['dafen','haku','meijiru'];

const MAKEUP_TIPS_HTML = `
<div style="margin-top:4px">
  <div style="font-size:12px;font-weight:600;color:inherit;margin-bottom:8px">💡 避免黏膩與起屑</div>
  <div style="font-size:11.5px;line-height:1.7;font-weight:300">
    <div style="margin-bottom:8px"><strong>1. 捨棄「胖粉」與「歐舒丹」</strong><br>妝前絕對不用胖粉（油脂含量高，會浮粉）；歐舒丹較滋潤，妝前統一換成大粉。</div>
    <div style="margin-bottom:8px"><strong>2. 等待「成膜」是靈魂</strong><br>擦完美肌乳後先去刷牙或整理頭髮，等 1–2 分鐘，感覺皮膚有一層乾爽薄膜感後，再上粉底或保養粉。</div>
    <div style="margin-bottom:8px"><strong>3. HAKU 或贈品金二選一且減半</strong><br>皮膚狀況好可直接跳過精華步驟，減少層次。</div>
    <div><strong>4. 皮膚粗糙/擔心粉底卡粉</strong><br>可先用「贈品藍」擦拭容易起皮的地方（如鼻翼），再拍上「大粉」。</div>
  </div>
</div>`;

// State
let currentDay = 0;
let currentMode = 'day'; 
let progress = {}; 
let weekDates = []; // Move here to persist shifts

function stateKey(d, m) { return d + '_' + m; }

function getRoutine(d, m) {
  if (m === 'makeup') return { steps: MAKEUP_STEPS };
  return WEEK.find(w => w.day === d && w.mode === m) || WEEK[0];
}

function getDone(d, m) {
  const k = stateKey(d, m);
  if (!progress[k]) progress[k] = new Set();
  return progress[k];
}

function toggleStep(idx) {
  const done = getDone(currentDay, currentMode);
  if (done.has(idx)) done.delete(idx);
  else done.add(idx);
  render();
}

// Init & Utils
function getWeekDates() {
  const now = new Date();
  const jsDay = now.getDay(); 
  const todayIdx = jsDay === 0 ? 6 : jsDay - 1; 
  const dates = [];
  for (let i = 0; i < 7; i++) {
    const diff = i - todayIdx;
    const d = new Date(now);
    d.setDate(now.getDate() + diff);
    dates.push(d);
  }
  return dates;
}

const WEEKDAY_SHORT = ['週一','週二','週三','週四','週五','週六','週日'];
const WEEKDAY_MINI  = ['一','二','三','四','五','六','日'];

function initDayScroll() {
  // 只有第一次載入時初始化，保留使用者切換後增加的日期
  if (weekDates.length === 0) {
    weekDates = getWeekDates();
  }
  const strip = document.getElementById('dayScroll');
  strip.innerHTML = '';
  WEEKDAY_MINI.forEach((label, i) => {
    const btn = document.createElement('button');
    btn.className = 'day-chip' + (i === currentDay ? ' active' : '');
    btn.id = 'daychip_' + i;
    const mDone = getDone(i, 'day').size > 0 || getDone(i,'night').size > 0 || getDone(i,'makeup').size > 0;
    if (mDone) btn.classList.add('has-done');

    const d = weekDates[i];
    const mo = d ? (d.getMonth()+1) : '';
    const dt = d ? d.getDate() : '';
    btn.innerHTML = `<span class="day-label">${label}</span>
      <span class="day-num">${mo}/${dt}</span>
      <span class="done-dot"></span>`;
    btn.onclick = () => { currentDay = i; render(); };
    strip.appendChild(btn);
  });
}

function updateDayScroll() {
  WEEKDAY_MINI.forEach((_, i) => {
    const chip = document.getElementById('daychip_' + i);
    if (!chip) return;
    chip.className = 'day-chip';
    if (i === currentDay) chip.classList.add('active');
    const mDone = getDone(i,'day').size>0 || getDone(i,'night').size>0 || getDone(i,'makeup').size>0;
    if (mDone) chip.classList.add('has-done');
    if (currentMode === 'night') chip.classList.add('day-chip-night');
  });
}

function setMode(m) {
  currentMode = m;
  render();
}

function applyNightTheme(on) {
  const app = document.getElementById('app');
  const header = document.getElementById('header');
  const modeBar = document.getElementById('modeBar');
  const ps = document.getElementById('progressSection');
  const div = document.getElementById('divider');
  const sl = document.getElementById('stepList');
  const title = document.getElementById('appTitle');
  const date = document.getElementById('todayDate');

  if (on) {
    app.classList.add('night-mode-bg');
    header.classList.add('night-header');
    modeBar.classList.add('night-mode-bar');
    ps.classList.add('night-progress');
    div.classList.add('night-divider');
    sl.classList.add('night-step-list');
    title.classList.add('app-title-night');
    date.classList.add('today-date-night');
  } else {
    app.classList.remove('night-mode-bg');
    header.classList.remove('night-header');
    modeBar.classList.remove('night-mode-bar');
    ps.classList.remove('night-progress');
    div.classList.remove('night-divider');
    sl.classList.remove('night-step-list');
    title.classList.remove('app-title-night');
    date.classList.remove('today-date-night');
  }
}

function render() {
  const isNight = currentMode === 'night';
  const isMakeup = currentMode === 'makeup';
  applyNightTheme(isNight);

  ['tabDay','tabNight','tabMakeup'].forEach(id => {
    const el = document.getElementById(id);
    el.classList.remove('active','night-active');
  });
  if (currentMode === 'day')    document.getElementById('tabDay').classList.add('active');
  if (currentMode === 'night')  document.getElementById('tabNight').classList.add('night-active');
  if (currentMode === 'makeup') document.getElementById('tabMakeup').classList.add('active');

  updateDayScroll();

  const routine = getRoutine(currentDay, currentMode);
  const steps = routine.steps;
  const done = getDone(currentDay, currentMode);
  
  // 進度條計算：排除 isOptional 的步驟
  const trackableStepsIndices = steps.map((pid, idx) => P[pid].isOptional ? -1 : idx).filter(i => i !== -1);
  const trackableTotal = trackableStepsIndices.length;
  const trackableDoneCount = trackableStepsIndices.filter(idx => done.has(idx)).length;

  document.getElementById('progressCount').textContent = trackableDoneCount + ' / ' + trackableTotal;
  document.getElementById('progressFill').style.width = (trackableTotal ? (trackableDoneCount/trackableTotal*100) : 0) + '%';
  document.getElementById('progressLabel').textContent =
    WEEKDAY_SHORT[currentDay] + (currentMode==='day'?' 日間':currentMode==='night'?' 夜間':' 化妝日');

  const list = document.getElementById('stepList');
  list.innerHTML = '';

  // 渲染步驟卡片
  steps.forEach((pid, i) => {
    const p = P[pid];
    const isDone = done.has(i);
    // 下一個要做的步驟（排除非必選）
    const nextIdx = trackableStepsIndices.find(idx => !done.has(idx));
    const isNext = i === nextIdx;

    const card = document.createElement('div');
    card.className = 'step-card' +
      (isNight ? ' night-card' : '') +
      (isDone ? ' is-done' : '') +
      (isNext && !isDone ? ' is-next' : '');
    card.onclick = () => toggleStep(i);

    const iconDiv = document.createElement('div');
    iconDiv.className = 'prod-icon';
    iconDiv.style.background = p.color;
    if (p.isMask) iconDiv.style.background = '#1A1A1A';
    iconDiv.innerHTML = p.icon;

    const body = document.createElement('div');
    body.className = 'step-body';
    body.innerHTML = `
      <div class="step-top-row">
        <span class="step-num">${i + 1}</span>
        <span class="step-badge badge-${p.tag}">${p.tagLabel}${p.isOptional ? ' (選填)' : ''}</span>
      </div>
      <div class="step-name">${p.name}</div>
      <div class="step-brand">${p.brand}</div>
      <div class="step-tip">${p.tip}</div>
    `;

    const checkWrap = document.createElement('div');
    checkWrap.className = 'check-wrap';
    const circle = document.createElement('div');
    circle.className = 'check-circle';
    if (isDone) {
      circle.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7L5.5 10L11.5 4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    }
    checkWrap.appendChild(circle);

    card.appendChild(iconDiv);
    card.appendChild(body);
    card.appendChild(checkWrap);
    list.appendChild(card);
  });

  // 全部完成橫幅
  if (trackableDoneCount === trackableTotal && trackableTotal > 0) {
    const banner = document.createElement('div');
    banner.className = 'done-banner' + (isNight ? ' night-done' : '');
    banner.innerHTML = `<div class="done-icon">${isNight ? nightMoonSVG : daySunSVG}</div>
      <div class="done-title">${isNight ? '晚安' : '完成了'}</div>
      <div class="done-sub">${WEEKDAY_SHORT[currentDay]}${currentMode==='day'?' 日間':currentMode==='night'?' 夜間':' 化妝日'}保養全部完成</div>`;
    list.appendChild(banner);
  }

  // 底部 REMINDER
  const rb = document.createElement('div');
  rb.className = 'section-note ' + (isNight ? 'note-night' : 'note-day');
  rb.style.marginTop = '16px';
  rb.innerHTML = '<strong>REMINDER：</strong>「小金條」須於 大粉、歐舒丹 或 面膜 後使用。';
  list.appendChild(rb);

  // 化妝日專屬提示
  if (isMakeup) {
    const tipsBox = document.createElement('div');
    tipsBox.className = 'section-note note-day';
    tipsBox.style.display = 'block';
    tipsBox.innerHTML = MAKEUP_TIPS_HTML;
    list.appendChild(tipsBox);
  }

  // 1. 重置本次進度按鈕
  const resetBtn = document.createElement('button');
  resetBtn.className = 'reset-btn' + (isNight ? ' night-reset' : '');
  resetBtn.textContent = '重置本次進度';
  resetBtn.onclick = (e) => {
    e.stopPropagation();
    progress[stateKey(currentDay, currentMode)] = new Set();
    render();
  };
  list.appendChild(resetBtn);

  // 2. 完成當日進度按鈕 (僅夜間模式顯示)
  if (isNight) {
    const completeBtn = document.createElement('button');
    completeBtn.className = 'reset-btn complete-btn';
    completeBtn.textContent = '完成當日進度';
    completeBtn.onclick = (e) => {
      e.stopPropagation();
      
      // 將當前日期的日期往後推 7 天
      const d = weekDates[currentDay];
      d.setDate(d.getDate() + 7);
      
      // 自動重置該天的 日間/夜晚/化妝日 進度
      progress[stateKey(currentDay, 'day')] = new Set();
      progress[stateKey(currentDay, 'night')] = new Set();
      progress[stateKey(currentDay, 'makeup')] = new Set();
      
      // 重新渲染上方日期滾動條
      initDayScroll();
      
      // 重新渲染畫面
      render();
    };
    list.appendChild(completeBtn);
  }
}

// Start
(function() {
  const now = new Date();
  const weekNames = ['週日','週一','週二','週三','週四','週五','週六'];
  document.getElementById('todayDate').innerHTML = `${weekNames[now.getDay()]}&nbsp;${now.getMonth() + 1}/${now.getDate()}`;
  const jsDay = now.getDay();
  currentDay = jsDay === 0 ? 6 : jsDay - 1;
})();

initDayScroll();
render();
</script>
